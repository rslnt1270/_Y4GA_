library(readxl)
# 1. Definir rutas (Arquitectura Modular)
input_xlsx <- "YAGA_DataSet_Final_R.xlsx"
output_csv <- "YAGA_DataSet_Final_Clean.csv"
# 2. Leer hoja específica (Evita metadatos corruptos)
# Asegúrate de que el nombre de la hoja sea correcto (ej: "Viajes_RED")
df_excel <- read_excel(input_xlsx, sheet = 1)
# 3. Exportación Limpia (Sin nulos, codificación estándar)
write.csv(df_excel, output_csv, row.names = FALSE, fileEncoding = "UTF-8")
message("SUCCESS: Archivo convertido a CSV bajo estándar YAGA (UTF-8).")
View(df_excel)
